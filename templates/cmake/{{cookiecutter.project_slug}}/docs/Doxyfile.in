# Doxyfile template for CMake configuration
PROJECT_NAME           = "@PROJECT_NAME@"
PROJECT_NUMBER         = "@PROJECT_VERSION@"
OUTPUT_DIRECTORY       = "@CMAKE_CURRENT_BINARY_DIR@/docs"
CREATE_SUBDIRS         = YES
ALLOW_UNICODE_NAMES    = NO
OUTPUT_LANGUAGE        = English
BRIEF_MEMBER_DESC      = YES
REPEAT_BRIEF           = YES

# Input settings
INPUT                  = "@CMAKE_CURRENT_SOURCE_DIR@/src" "@CMAKE_CURRENT_SOURCE_DIR@/include"
INPUT_ENCODING         = UTF-8
FILE_PATTERNS          = *.c \
                         *.cc \
                         *.cxx \
                         *.cpp \
                         *.h \
                         *.hh \
                         *.hxx \
                         *.hpp
RECURSIVE              = YES
EXCLUDE                =
EXCLUDE_PATTERNS       = */build/* */tests/*

# Source browsing
SOURCE_BROWSER         = YES
INLINE_SOURCES         = NO
STRIP_CODE_COMMENTS    = YES

# HTML generation
GENERATE_HTML          = YES
HTML_OUTPUT            = html
HTML_FILE_EXTENSION    = .html

# LaTeX generation (disabled by default)
GENERATE_LATEX         = NO

CALL_GRAPH             = YES
CALLER_GRAPH           = YES
UML_LOOK               = YES

HAVE_DOT               = YES
EXTRACT_ALL            = YES
EXTRACT_LOCAL_CLASSES  = YES
EXTRACT_PRIVATE        = YES

EXTRACT_STATIC         = YES

REFERENCED_BY_RELATION = NO
REFERENCES_RELATION    = NO